# =========================================================
# HEKAS POS API — Environment Variables (EXAMPLE / TEMPLATE)
# =========================================================
# Copy file ini jadi `.env` dan isi nilai sesuai environment.
# JANGAN commit `.env` ke git (sudah di .gitignore).

# ====== APP ======
NODE_ENV=development
APP_NAME="HEKAS POS API"
APP_PORT=3001
APP_VERSION=0.1.0
APP_BASE_URL=http://localhost:3001
APP_CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# ====== DATABASE ======
DATABASE_URL=postgres://hekas:hekas_dev_password_change_me@localhost:5432/hekas_pos
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Test database (untuk integration test)
DATABASE_URL_TEST=postgres://hekas:hekas_dev_password_change_me@localhost:5432/hekas_pos_test

# ====== AUTH ======
# JWT_SECRET: minimal 32 karakter random. Generate: openssl rand -base64 48
JWT_SECRET=replace_me_with_64_chars_random_string_for_jwt_signing_security
JWT_ACCESS_EXPIRES_IN=900          # 15 menit (detik)
JWT_REFRESH_EXPIRES_IN=2592000     # 30 hari (detik)
PIN_MAX_ATTEMPTS=5
PIN_LOCKOUT_WINDOW=3600            # 1 jam (detik)

# ====== TELEGRAM ======
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_URL=
TELEGRAM_POLLING=false             # true = long polling (dev), false = webhook (prod)
TELEGRAM_MAX_RETRY=5

# ====== WORKERS (pg-boss) ======
PGBOSS_SCHEMA=pgboss
PGBOSS_MIGRATE=true
WORKER_CONCURRENCY=2

# ====== STORAGE ======
UPLOAD_DIR=./static/uploads
MAX_UPLOAD_SIZE_MB=10

# PDF generation
PDF_OUTPUT_DIR=./static/pdfs

# ====== LOGGING ======
LOG_LEVEL=info                     # trace|debug|info|warn|error|fatal
LOG_PRETTY=true                    # true = pino-pretty (dev), false = JSON (prod)

# ====== RATE LIMITING ======
RATE_LIMIT_WINDOW=60000            # 1 menit (ms)
RATE_LIMIT_MAX=100                 # 100 req per window per IP

# ====== MONITORING ======
SENTRY_DSN=
HEALTH_CHECK_PATH=/api/health

# ====== FEATURE FLAGS ======
ENABLE_AI=false                    # Tahap 2
ENABLE_PDF_EXPORT=true
ENABLE_TELEGRAM=false              # Set true setelah setup bot
ENABLE_SWAGGER=true

# ====== SEED (development only) ======
SEED_DEFAULT_PASSWORD=password123