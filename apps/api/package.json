{
  "name": "@hekas/api",
  "version": "0.1.0",
  "private": true,
  "description": "HEKAS POS API — ElysiaJS + Drizzle ORM + Bun",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "build": "bun build src/index.ts --target=bun --outdir=dist",
    "start": "bun run dist/index.js",
    "test": "bun test",
    "test:unit": "bun test tests/unit",
    "test:integration": "bun test tests/integration",
    "lint": "echo 'lint placeholder (add eslint later)'",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun run src/db/seed.ts",
    "db:reset": "bun run scripts/db-reset.ts",
    "db:drop": "drizzle-kit drop"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/eden": "^1.1.0",
    "@elysiajs/jwt": "^1.4.2",
    "@elysiajs/swagger": "^1.3.1",
    "@hekas/shared": "workspace:*",
    "@node-rs/argon2": "^2.0.2",
    "argon2": "^0.41.0",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.29",
    "exceljs": "^4.4.0",
    "grammy": "^1.30.0",
    "nanoid": "^5.0.8",
    "pdfkit": "^0.19.1",
    "pg": "^8.13.0",
    "pg-boss": "^12.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.9",
    "puppeteer": "^23.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "@types/pdfkit": "^0.17.6",
    "@types/pg": "^8.11.10",
    "typescript": "^5.6.3"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}